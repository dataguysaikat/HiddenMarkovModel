# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# Charles Schwab API credentials
SCHWAB_APP_KEY=your_schwab_app_key_here
SCHWAB_APP_SECRET=your_schwab_app_secret_here
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182
SCHWAB_TOKEN_PATH=data/schwab_token.json

# Set to "paper" to paper-trade locally, "live" to execute real orders
TRADE_MODE=paper
